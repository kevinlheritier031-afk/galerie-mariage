# ─── Supabase self-hosted ──────────────────────────────────────────────────────
# URL de votre instance Supabase (ex: http://141.94.121.159:8000)
VITE_SUPABASE_URL=

# Clé publique anon — visible côté client, utilisée pour lectures/inserts/Realtime
VITE_SUPABASE_ANON_KEY=

# Clé service role — JAMAIS exposée en public, utilisée uniquement dans le panel admin
# pour les suppressions qui bypassent les Row Level Security policies
VITE_SUPABASE_SERVICE_KEY=

# ─── Sécurité ─────────────────────────────────────────────────────────────────
# Mot de passe d'accès au panel /admin
VITE_ADMIN_PASSWORD=

# Code secret pour le mode de téléchargement "protected" (post-soirée)
# Partagez ce code par SMS aux invités après la soirée
VITE_DOWNLOAD_CODE=

# ─── Application ──────────────────────────────────────────────────────────────
# URL publique de l'application (ex: https://galerie-mariage.vercel.app)
# Utilisée pour générer le QR code dans le panel admin
VITE_APP_URL=

# ─── Limites vidéo ────────────────────────────────────────────────────────────
# Durée maximale des vidéos acceptées (en secondes)
VITE_MAX_VIDEO_DURATION=180

# Taille maximale des vidéos acceptées (en mégaoctets)
VITE_MAX_VIDEO_SIZE_MB=100

# ─── API disque (côté serveur uniquement) ─────────────────────────────────────
# URL de l'API Express disk-api sur le VPS
# Variable sans VITE_ car utilisée uniquement dans la Vercel Edge Function
# et jamais exposée au navigateur
# Ex: http://141.94.121.159:3001
DISK_API_URL=

{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/supabase-proxy/rest/v1/:path*",
      "destination": "http://141.94.121.159:8000/rest/v1/:path*"
    },
    {
      "source": "/supabase-proxy/realtime/v1/:path*",
      "destination": "http://141.94.121.159:8000/realtime/v1/:path*"
    },
    {
      "source": "/supabase-proxy/storage/v1/:path*",
      "destination": "http://141.94.121.159:8000/storage/v1/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
